---
const title = "Juan José Trujillo Cardozo · Software Engineer";
const description = "Software Engineer · Founder @ TRUJO TECHNOLOGIES SAS · Data Governance @ Inetum (BBVA) · Bogotá, Colombia.";
const url = "https://juan.trujotechnologies.com";
---
<!DOCTYPE html>
<html lang="es">
<head>
<meta charset="UTF-8" />
<meta name="viewport" content="width=device-width, initial-scale=1.0" />
<title>{title}</title>
<meta name="description" content={description} />
<link rel="canonical" href={url} />
<link rel="icon" href="/favicon.ico" />

<meta property="og:type" content="profile" />
<meta property="og:title" content={title} />
<meta property="og:description" content={description} />
<meta property="og:image" content={`${url}/avatar-og.jpg`} />
<meta property="og:url" content={url} />
<meta property="og:locale" content="es_CO" />
<meta name="twitter:card" content="summary_large_image" />
<meta name="twitter:title" content={title} />
<meta name="twitter:description" content={description} />
<meta name="twitter:image" content={`${url}/avatar-og.jpg`} />

<link rel="preconnect" href="https://fonts.googleapis.com" />
<link rel="preconnect" href="https://fonts.gstatic.com" crossorigin />
<link href="https://fonts.googleapis.com/css2?family=Inter:wght@400;500;600;700;800&family=JetBrains+Mono:wght@400;500&display=swap" rel="stylesheet" />

<style>
:root {
  --bg: #0f172a;
  --surface: #1e293b;
  --border: rgba(255,255,255,0.08);
  --text: #f8fafc;
  --text-muted: #94a3b8;
  --text-subtle: #64748b;
  --accent: #10b981;
  --accent-glow: rgba(16,185,129,0.35);
  --accent-soft: rgba(16,185,129,0.12);
  --mono: 'JetBrains Mono', ui-monospace, SFMono-Regular, monospace;
}
* { box-sizing: border-box; margin: 0; padding: 0; }
html { scroll-behavior: smooth; }
body {
  background: var(--bg);
  background-image:
    radial-gradient(circle at 0% 0%, rgba(16,185,129,0.08) 0%, transparent 30%),
    radial-gradient(circle at 100% 80%, rgba(16,185,129,0.05) 0%, transparent 35%);
  color: var(--text);
  font-family: 'Inter', system-ui, -apple-system, Segoe UI, sans-serif;
  line-height: 1.6;
  min-height: 100vh;
  -webkit-font-smoothing: antialiased;
}
.brand-bar {
  position: fixed; top: 0; left: 0;
  width: 4px; height: 80px;
  background: var(--accent);
  border-radius: 0 4px 4px 0;
}
.container { max-width: 880px; margin: 0 auto; padding: 0 24px; }
header { padding: 64px 0 40px; }
.hero { display: flex; flex-direction: column; align-items: flex-start; gap: 24px; }
.hero img.avatar {
  width: 120px; height: 120px;
  border-radius: 50%;
  border: 3px solid var(--accent);
  box-shadow: 0 0 40px var(--accent-glow);
}
h1 { font-size: clamp(2rem, 5vw, 3rem); font-weight: 800; letter-spacing: -0.025em; line-height: 1.1; }
.tagline { font-size: 1.125rem; color: var(--text-muted); font-weight: 500; }
.tagline .accent { color: var(--accent); font-weight: 600; }
.stack-line { font-family: var(--mono); font-size: 0.85rem; color: var(--text-subtle); margin-top: 4px; }
.stack-line span { color: var(--accent); }

section { padding: 56px 0; border-top: 1px solid var(--border); }
section:first-of-type { border-top: none; }
.section-label { font-size: 0.75rem; text-transform: uppercase; letter-spacing: 0.12em; color: var(--accent); font-weight: 600; margin-bottom: 12px; font-family: var(--mono); }
h2 { font-size: 1.75rem; font-weight: 700; margin-bottom: 20px; letter-spacing: -0.02em; }
p.body { color: var(--text-muted); font-size: 1rem; max-width: 65ch; margin-bottom: 16px; }
p.body strong { color: var(--text); font-weight: 600; }

.skills { display: flex; flex-wrap: wrap; gap: 8px; }
.skill {
  font-family: var(--mono);
  font-size: 0.8rem;
  padding: 6px 12px;
  background: var(--accent-soft);
  border: 1px solid rgba(16,185,129,0.25);
  border-radius: 6px;
  color: var(--accent);
}

.projects { display: grid; grid-template-columns: repeat(auto-fit, minmax(240px, 1fr)); gap: 16px; }
.project {
  background: var(--surface);
  border: 1px solid var(--border);
  border-radius: 12px;
  padding: 20px;
  text-decoration: none;
  color: inherit;
  transition: transform 0.2s ease, border-color 0.2s ease, box-shadow 0.2s ease;
  display: flex; flex-direction: column;
}
.project:hover { transform: translateY(-3px); border-color: var(--accent); box-shadow: 0 8px 24px rgba(16,185,129,0.15); }
.project h3 { font-size: 1rem; font-weight: 600; margin-bottom: 8px; }
.project p { font-size: 0.85rem; color: var(--text-muted); flex-grow: 1; }
.project .arrow { color: var(--accent); font-size: 0.85rem; margin-top: 12px; font-weight: 600; }

.timeline { list-style: none; display: flex; flex-direction: column; gap: 14px; }
.timeline li {
  display: grid;
  grid-template-columns: 160px 1fr;
  gap: 18px;
  padding: 12px 0;
  border-bottom: 1px dashed var(--border);
}
.timeline li:last-child { border-bottom: none; }
.timeline-date {
  font-family: var(--mono);
  font-size: 0.75rem;
  color: var(--accent);
  letter-spacing: 0.04em;
  padding-top: 3px;
}
.timeline-role { display: block; font-size: 0.95rem; color: var(--text); line-height: 1.4; }
.timeline-role strong { font-weight: 600; }
.timeline-meta { display: block; font-size: 0.8rem; color: var(--text-muted); margin-top: 4px; font-family: var(--mono); }
@media (max-width: 600px) {
  .timeline li { grid-template-columns: 1fr; gap: 4px; }
}

.contact-grid { display: grid; grid-template-columns: repeat(auto-fit, minmax(180px, 1fr)); gap: 12px; }
.contact-link {
  background: var(--surface);
  border: 1px solid var(--border);
  border-radius: 10px;
  padding: 14px 16px;
  text-decoration: none;
  color: var(--text);
  display: flex; align-items: center; gap: 10px;
  font-size: 0.9rem; font-weight: 500;
  transition: border-color 0.2s, background 0.2s;
}
.contact-link:hover { border-color: var(--accent); background: rgba(16,185,129,0.05); }
.contact-link svg { color: var(--accent); flex-shrink: 0; }

footer { padding: 40px 0 60px; border-top: 1px solid var(--border); margin-top: 32px; color: var(--text-subtle); font-size: 0.8rem; text-align: center; }
footer a { color: var(--accent); text-decoration: none; }
footer .meta { font-family: var(--mono); margin-top: 6px; font-size: 0.75rem; opacity: 0.7; }

@media (max-width: 600px) {
  header { padding: 48px 0 32px; }
  section { padding: 40px 0; }
  .hero img.avatar { width: 96px; height: 96px; }
}
</style>
</head>
<body>
<div class="brand-bar"></div>

<div class="container">
  <header>
    <div class="hero">
      <img src="/avatar.png" alt="Juan José Trujillo Cardozo" class="avatar" width="120" height="120" />
      <div>
        <h1>Juan José Trujillo Cardozo</h1>
        <p class="tagline">
          Software Engineer · Founder <span class="accent">@ TRUJO TECHNOLOGIES SAS</span><br/>
          Data Governance Analyst @ Inetum (BBVA Riesgos)
        </p>
        <p class="stack-line">
          <span>FastAPI</span> · <span>Next.js</span> · <span>PostgreSQL</span> · <span>Docker</span> · <span>C# WinForms</span> · <span>AWS</span> · <span>GCP</span>
        </p>
      </div>
    </div>
  </header>

  <section>
    <p class="section-label">// Sobre mí</p>
    <h2>Construyo software que las empresas colombianas usan en producción</h2>
    <p class="body">
      Ingeniero de Sistemas (Universidad Piloto de Colombia), con C2 inglés certificado y formación adicional en notación musical (UNAD).
      Nacido en Bogotá en 2001.
    </p>
    <p class="body">
      Hoy trabajo como <strong>Data Governance Analyst en Inetum</strong>, sobre el proyecto BBVA Riesgos Launchpad
      (PySpark + AWS EMR + SageMaker, datos institucionales bajo cluster controlado del banco).
    </p>
    <p class="body">
      En paralelo soy <strong>fundador de TRUJO TECHNOLOGIES SAS</strong> (NIT 902.025.831-4, constituida 16 ene 2026).
      Construyo infraestructura técnica para PyMEs colombianas reguladas: bots WhatsApp con IA, control biométrico offline,
      facturación electrónica DIAN nativa, y monitoreo SLA con Docker + Postgres 16 multi-tenant + Cloudflare.
    </p>
  </section>

  <section>
    <p class="section-label">// Stack</p>
    <h2>Lo que construyo, con qué</h2>
    <div class="skills">
      <span class="skill">Python</span>
      <span class="skill">TypeScript</span>
      <span class="skill">C#</span>
      <span class="skill">Go</span>
      <span class="skill">FastAPI</span>
      <span class="skill">Next.js 14</span>
      <span class="skill">React</span>
      <span class="skill">Astro</span>
      <span class="skill">PostgreSQL 16</span>
      <span class="skill">Redis</span>
      <span class="skill">Docker</span>
      <span class="skill">Nginx</span>
      <span class="skill">AWS</span>
      <span class="skill">GCP</span>
      <span class="skill">Cloudflare</span>
      <span class="skill">PySpark</span>
      <span class="skill">SageMaker</span>
      <span class="skill">n8n</span>
      <span class="skill">Tailwind</span>
      <span class="skill">Prisma</span>
    </div>
  </section>

  <section>
    <p class="section-label">// En producción hoy</p>
    <h2>Proyectos vivos</h2>
    <div class="projects">
      <a href="https://trujotechnologies.com" class="project" target="_blank" rel="noopener">
        <h3>TRUJO TECHNOLOGIES</h3>
        <p>SaaS multi-tenant para PyMEs colombianas. POS DIAN, bot WhatsApp con IA, biometría, infraestructura gestionada.</p>
        <span class="arrow">trujotechnologies.com →</span>
      </a>
      <a href="https://biometrico.trujotechnologies.com" class="project" target="_blank" rel="noopener">
        <h3>Sistema Biométrico</h3>
        <p>C# WinForms + DigitalPersona U.are.U. Modo offline 48h. 200+ heartbeats/sem en producción Espinal + Fusagasugá.</p>
        <span class="arrow">biometrico.trujotechnologies.com →</span>
      </a>
      <a href="https://trujovids.trujotechnologies.com" class="project" target="_blank" rel="noopener">
        <h3>TRUJO VIDS</h3>
        <p>Proyecto personal creator desde 2016. Minecraft, streaming, comunidad LOS TRUJOS. +580 subs YouTube.</p>
        <span class="arrow">trujovids.trujotechnologies.com →</span>
      </a>
    </div>
  </section>

  <section>
    <p class="section-label">// Trayectoria</p>
    <h2>Experiencia</h2>
    <ul class="timeline">
      <li>
        <span class="timeline-date">2025 — Hoy</span>
        <span class="timeline-role"><strong>Data Governance Analyst</strong> · Inetum (cliente BBVA Riesgos)</span>
        <span class="timeline-meta">PySpark · AWS EMR · SageMaker · Cluster controlado BBVA</span>
      </li>
      <li>
        <span class="timeline-date">2026 — Hoy</span>
        <span class="timeline-role"><strong>Founder &amp; Engineer</strong> · TRUJO TECHNOLOGIES S.A.S.</span>
        <span class="timeline-meta">NIT 902.025.831-4 · Constituida 16 ene 2026 · Producción en clientes reales</span>
      </li>
      <li>
        <span class="timeline-date">2022 — 2023</span>
        <span class="timeline-role"><strong>Cajero</strong> · Pizzería Hoyo 19</span>
        <span class="timeline-meta">Atención al cliente · POS · Cierre de caja</span>
      </li>
      <li>
        <span class="timeline-date">2019 — 2020</span>
        <span class="timeline-role"><strong>Cajero</strong> · Ramona Pizza Artesanal</span>
        <span class="timeline-meta">Atención al cliente · POS · Cierre de caja</span>
      </li>
    </ul>
  </section>

  <section>
    <p class="section-label">// Formación</p>
    <h2>Educación</h2>
    <ul class="timeline">
      <li>
        <span class="timeline-date">2019 — 2024</span>
        <span class="timeline-role"><strong>Ingeniería de Sistemas</strong> · Universidad Piloto de Colombia</span>
      </li>
      <li>
        <span class="timeline-date">2016 — 2018</span>
        <span class="timeline-role"><strong>Técnico en Sistemas</strong> · SENA</span>
      </li>
      <li>
        <span class="timeline-date">Mar — Abr 2023</span>
        <span class="timeline-role"><strong>Curso UI/UX · Adobe XD</strong> · EduGreen Training</span>
      </li>
      <li>
        <span class="timeline-date">2024 — Hoy</span>
        <span class="timeline-role"><strong>Cursos UNAD</strong> · Edición Musical (Finale, notación profesional)</span>
      </li>
    </ul>
    <p class="body" style="margin-top:20px"><strong>Inglés</strong> · C2 certificado (EF SET 75+).</p>
  </section>

  <section>
    <p class="section-label">// Contacto</p>
    <h2>Hablemos</h2>
    <div class="contact-grid">
      <a href="https://www.linkedin.com/in/juanjosetrujillocardozo/" class="contact-link" target="_blank" rel="noopener">
